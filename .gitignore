```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Dependencies
.venv/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
htmlcov/

# Logs
*.log

# Environment variables
.env
.env.local
.env.*
!.env.example

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
```